{
  "name": "efemer/efemer",
  "repositories": [
    {
      "url": "https://github.com/criq/katu",
      "type": "git"
    },
    {
      "url": "https://github.com/criq/sexy",
      "type": "git"
    }
  ],
  "require": {
    "criq/katu": "^4",
    "criq/sexy": "^4",
    "google/cloud": "@stable",
    "nyholm/psr7": "^1.8"
  },
  "autoload": {
    "psr-4": {
      "App\\": "./app/"
    }
  },
  "scripts": {
    "post-create-project-cmd": [
      "npm install"
    ],
    "migrate": "php bin/migrate.php"
  },
  "config": {
    "audit": {
      "block-insecure": false
    }
  }
}

{% extends "Templates/default.twig" %}

{% block body %}

	<div class="container">
		<div class="row">
			<div class="col-auto">

				<h1>
					Stránky
				</h1>

			</div>
		</div>
		<div class="row">
			<div class="col-auto">

				<p>
					<a class="btn btn-primary" href="{{ url("admin.posts.create") }}">
						Přidat
					</a>
				</p>

			</div>
		</div>
		<div class="row">
			<div class="col-12">

				<table class="table">
					<tbody>
						{% for post in posts %}
							<tr>
								<td class="narrow nowrap">
									<a href="{{ url("admin.posts.view", { postId: post.getId }) }}">
										{{ post.getId }}
									</a>
								</td>
								<td>
									<img class="img-fluid" src="{{ post.getPostBlockFiles.getFirst.getImage.getImageVersion("THUMBNAIL") }}" alt="">
								</td>
								<td class="narrow nowrap">
									<a class="btn btn-primary" href="{{ url("admin.posts.view", { postId: post.getId }) }}">
										Upravit
									</a>
								</td>
								<td class="narrow nowrap">
									<a class="btn btn-danger" href="{{ url("admin.posts.view", { postId: post.getId }) }}">
										Smazat
									</a>
								</td>
							</tr>
						{% endfor %}
					</tbody>
				</table>

			</div>
		</div>
	</div>

{% endblock body %}

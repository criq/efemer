<a class="page-page-gallery__item page-page-gallery__item--image-only" href="{{ linkedPage.getPublicUrl }}">
	{% set thumbnail = linkedPage.getStorageFiles.getFirst %}
	{% if thumbnail and thumbnail.getImage %}
		<img class="page-page-gallery__image" src="{{ thumbnail.getImage.getImageVersion("GALLERY").getURL }}" alt="{{ linkedPage.getTitle|default("") }}">
	{% endif %}
</a>

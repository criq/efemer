<!DOCTYPE html>
<html lang="cs">
	<head>

		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1">
		<title>{% block title %}Admin{% endblock %} · Efemer</title>

		<link rel="stylesheet" href="/css/main.css">
		<link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0">

		<script src="https://cdn.tiny.cloud/1/e20azgvvzznqr9wr35zn4pjkyr7zqrj0klyaa9dq1nkm1zeg/tinymce/7/tinymce.min.js" referrerpolicy="origin"></script>

	</head>
	<body class="admin">

		<header class="admin-header">
			<div class="admin-header__inner">
				<a class="admin-header__brand" href="{{ url("admin.pages.index") }}">Efemer</a>
				<nav class="admin-header__nav">
					<a class="admin-header__link" href="{{ url("admin.pages.index") }}">{% include "Blocks/adminIcon.twig" with { name: "description" } %} Stránky</a>
					<a class="admin-header__link" href="{{ url("admin.storageFiles.index") }}">{% include "Blocks/adminIcon.twig" with { name: "perm_media" } %} Soubory</a>
					<a class="admin-header__link admin-header__link--muted" href="{{ url("homepage.index") }}">{% include "Blocks/adminIcon.twig" with { name: "public" } %} Web</a>
				</nav>
			</div>
		</header>

		<main class="admin-main">
			{% block body %}
			{% endblock body %}
		</main>

		<script src="/javascript/app.js"></script>

		<script>
			document.querySelectorAll("[data-storage-files]").forEach((root) => {
				const table = root.querySelector(".admin-storage-files__table");
				const body = root.querySelector(".admin-storage-files__body");
				const drop = root.querySelector("[data-file-drop]");
				const input = drop.querySelector(".admin-file-drop__input");
				const zone = drop.querySelector(".admin-file-drop__zone");
				const errorEl = root.querySelector(".admin-storage-files__error");
				const multiple = root.hasAttribute("data-storage-files-multiple");
				const uploadUrl = root.dataset.uploadUrl;
				const updateUrlTemplate = root.dataset.updateUrlTemplate;
				const deleteUrlTemplate = root.dataset.deleteUrlTemplate;
				const reorderUrl = root.dataset.reorderUrl || "";
				const token = root.dataset.token;
				let activeUploads = 0;
				let draggedRow = null;

				const showError = (message) => {
					errorEl.textContent = message;
					errorEl.hidden = !message;
				};

				const setUploading = (isUploading) => {
					drop.classList.toggle("is-uploading", isUploading);
					zone.toggleAttribute("aria-busy", isUploading);
				};

				const showTable = () => {
					table.hidden = false;
				};

				const getOrder = () => [...body.querySelectorAll("tr[data-storage-file-id]")].map((row) => row.dataset.storageFileId);

				const saveOrder = async () => {
					if (!reorderUrl) {
						return;
					}

					const formData = new FormData();
					formData.append("formToken", token);
					formData.append("storageFileOrder", getOrder().join(","));

					const response = await fetch(reorderUrl, {
						method: "POST",
						body: formData,
						headers: { Accept: "application/json" },
					});

					if (!response.ok) {
						throw new Error("Uložení pořadí se nezdařilo.");
					}
				};

				const saveCaption = async (id, caption) => {
					const formData = new FormData();
					formData.append("formToken", token);
					formData.append("caption", caption);

					const response = await fetch(updateUrlTemplate.replace("__id__", String(id)), {
						method: "POST",
						body: formData,
						headers: { Accept: "application/json" },
					});

					if (!response.ok) {
						throw new Error("Uložení popisku se nezdařilo.");
					}
				};

				const registerCaption = (input, id) => {
					if (input.dataset.captionBound === "true") {
						return;
					}

					input.dataset.captionBound = "true";

					input.addEventListener("blur", async () => {
						try {
							await saveCaption(id, input.value.trim());
							showError("");
						} catch (error) {
							showError(error.message);
						}
					});
				};

				const createRow = (file) => {
					const row = document.createElement("tr");
					row.dataset.storageFileId = String(file.id);

					if (multiple) {
						const handleCell = document.createElement("td");
						handleCell.className = "admin-table__handle";
						handleCell.setAttribute("draggable", "true");
						handleCell.innerHTML = "<span class=\"admin-icon material-symbols-outlined\" aria-label=\"Přesunout\">drag_indicator</span>";
						row.appendChild(handleCell);
					}

					const previewCell = document.createElement("td");
					previewCell.className = "admin-storage-files__preview";

					if (file.thumbnailUrl) {
						const image = document.createElement("img");
						image.className = "admin-storage-files__image";
						image.src = file.thumbnailUrl;
						image.alt = file.fileName || "";
						image.draggable = false;
						previewCell.appendChild(image);
					}

					row.appendChild(previewCell);

					const captionCell = document.createElement("td");
					const captionInput = document.createElement("input");
					captionInput.className = "admin-storage-files__caption";
					captionInput.type = "text";
					captionInput.value = file.caption || "";
					captionInput.placeholder = "Popisek obrázku";
					captionCell.appendChild(captionInput);
					row.appendChild(captionCell);

					const actionsCell = document.createElement("td");
					actionsCell.className = "admin-table__actions";
					const deleteButton = document.createElement("button");
					deleteButton.className = "admin-button admin-button--danger";
					deleteButton.type = "button";
					deleteButton.setAttribute("aria-label", "Smazat");
					deleteButton.innerHTML = "<span class=\"admin-icon material-symbols-outlined\" aria-hidden=\"true\">delete</span>";
					deleteButton.addEventListener("click", () => deleteFile(file.id, row));
					actionsCell.appendChild(deleteButton);
					row.appendChild(actionsCell);

					registerCaption(captionInput, file.id);
					registerSortableRow(row);

					return row;
				};

				const createUploadRow = (file) => {
					const row = document.createElement("tr");
					row.className = "is-uploading";

					if (multiple) {
						row.appendChild(document.createElement("td"));
					}

					const previewCell = document.createElement("td");
					previewCell.className = "admin-storage-files__preview";

					const image = document.createElement("img");
					image.className = "admin-storage-files__image";
					image.src = URL.createObjectURL(file);
					image.alt = file.name;
					previewCell.appendChild(image);

					const progress = document.createElement("div");
					progress.className = "admin-storage-files__upload-progress";
					const progressBar = document.createElement("div");
					progressBar.className = "admin-storage-files__upload-progress-bar";
					progressBar.setAttribute("role", "progressbar");
					progressBar.setAttribute("aria-valuemin", "0");
					progressBar.setAttribute("aria-valuemax", "100");
					progressBar.setAttribute("aria-valuenow", "0");
					progress.appendChild(progressBar);
					previewCell.appendChild(progress);

					row.appendChild(previewCell);
					row.appendChild(document.createElement("td"));
					row.appendChild(document.createElement("td"));

					row.addEventListener("uploadComplete", () => {
						URL.revokeObjectURL(image.src);
					}, { once: true });

					return { row, progressBar };
				};

				const setProgress = (progressBar, value) => {
					const percent = Math.max(0, Math.min(100, Math.round(value * 100)));
					progressBar.style.width = `${percent}%`;
					progressBar.setAttribute("aria-valuenow", String(percent));
				};

				const registerSortableRow = (row) => {
					if (!reorderUrl || row.dataset.sortableBound === "true") {
						return;
					}

					const handle = row.querySelector(".admin-table__handle");
					if (!handle) {
						return;
					}

					row.dataset.sortableBound = "true";

					handle.addEventListener("dragstart", (event) => {
						draggedRow = row;
						row.classList.add("is-dragging");
						event.dataTransfer.effectAllowed = "move";
					});

					handle.addEventListener("dragend", async () => {
						row.classList.remove("is-dragging");
						draggedRow = null;

						try {
							await saveOrder();
							showError("");
						} catch (error) {
							showError(error.message);
						}
					});

					row.addEventListener("dragover", (event) => {
						event.preventDefault();

						if (!draggedRow || draggedRow === row || row.classList.contains("is-uploading")) {
							return;
						}

						const rows = [...body.querySelectorAll("tr[data-storage-file-id]:not(.is-dragging)")];
						const nextRow = rows.find((candidate) => {
							const rect = candidate.getBoundingClientRect();

							return event.clientY <= rect.top + rect.height / 2;
						});

						if (nextRow) {
							body.insertBefore(draggedRow, nextRow);
						} else {
							body.appendChild(draggedRow);
						}
					});
				};

				const uploadFile = (file, progressBar) => new Promise((resolve, reject) => {
					const xhr = new XMLHttpRequest();
					xhr.open("POST", uploadUrl);
					xhr.setRequestHeader("Accept", "application/json");

					xhr.upload.addEventListener("progress", (event) => {
						if (event.lengthComputable) {
							setProgress(progressBar, event.loaded / event.total);
						}
					});

					xhr.addEventListener("load", () => {
						let data = null;

						try {
							data = JSON.parse(xhr.responseText);
						} catch (error) {
							reject(new Error("Nahrávání se nezdařilo."));
							return;
						}

						if (xhr.status < 200 || xhr.status >= 300) {
							const message = data.errors?.[0]?.message || data[0]?.message || "Nahrávání se nezdařilo.";
							reject(new Error(message));
							return;
						}

						resolve(data);
					});

					xhr.addEventListener("error", () => {
						reject(new Error("Nahrávání se nezdařilo."));
					});

					const formData = new FormData();
					formData.append("formToken", token);
					formData.append("files[]", file);
					xhr.send(formData);
				});

				const uploadFiles = async (files) => {
					const fileList = multiple ? [...files] : [files[0]].filter(Boolean);
					if (!fileList.length) {
						return;
					}

					showError("");
					showTable();

					if (!multiple) {
						body.querySelectorAll("tr[data-storage-file-id]").forEach((row) => row.remove());
					}

					const uploads = fileList.map((file) => {
						const { row, progressBar } = createUploadRow(file);
						body.appendChild(row);
						return { file, row, progressBar };
					});

					activeUploads += uploads.length;
					setUploading(true);

					await Promise.all(uploads.map(async ({ file, row, progressBar }) => {
						try {
							const data = await uploadFile(file, progressBar);
							setProgress(progressBar, 1);
							row.dispatchEvent(new Event("uploadComplete"));

							const uploadedFile = (data.files || [])[0];
							if (!uploadedFile) {
								throw new Error("Nahrávání se nezdařilo.");
							}

							row.replaceWith(createRow(uploadedFile));
						} catch (error) {
							row.dispatchEvent(new Event("uploadComplete"));
							row.remove();
							showError(error.message);
						} finally {
							activeUploads -= 1;
							if (activeUploads === 0) {
								setUploading(false);
								input.value = "";

								if (!body.querySelector("tr[data-storage-file-id]")) {
									table.hidden = true;
								}
							}
						}
					}));
				};

				const deleteFile = async (id, row) => {
					showError("");
					row.classList.add("is-deleting");

					const formData = new FormData();
					formData.append("formToken", token);

					try {
						const response = await fetch(deleteUrlTemplate.replace("__id__", String(id)), {
							method: "POST",
							body: formData,
							headers: { Accept: "application/json" },
						});

						if (!response.ok) {
							throw new Error("Smazání se nezdařilo.");
						}

						row.remove();

						if (!body.querySelector("tr[data-storage-file-id]")) {
							table.hidden = true;
						}
					} catch (error) {
						row.classList.remove("is-deleting");
						showError(error.message);
					}
				};

				body.querySelectorAll("tr[data-storage-file-id]").forEach((row) => {
					const deleteButton = row.querySelector(".admin-button--danger");
					deleteButton.addEventListener("click", () => deleteFile(row.dataset.storageFileId, row));
					registerCaption(row.querySelector(".admin-storage-files__caption"), row.dataset.storageFileId);
					registerSortableRow(row);
				});

				zone.addEventListener("click", () => input.click());

				zone.addEventListener("keydown", (event) => {
					if (event.key === "Enter" || event.key === " ") {
						event.preventDefault();
						input.click();
					}
				});

				input.addEventListener("change", () => {
					if (input.files.length > 0) {
						uploadFiles(input.files);
					}
				});

				["dragenter", "dragover"].forEach((eventName) => {
					zone.addEventListener(eventName, (event) => {
						event.preventDefault();
						drop.classList.add("is-over");
					});
				});

				zone.addEventListener("dragleave", (event) => {
					if (!zone.contains(event.relatedTarget)) {
						drop.classList.remove("is-over");
					}
				});

				zone.addEventListener("drop", (event) => {
					event.preventDefault();
					drop.classList.remove("is-over");

					if (event.dataTransfer.files.length > 0) {
						uploadFiles(event.dataTransfer.files);
					}
				});
			});
		</script>

	</body>
</html>

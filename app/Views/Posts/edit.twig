{% extends "Templates/default.twig" %}

{% block body %}

	<div class="container">
		<div class="row">
			<div class="col-auto">

			<form action="" method="POST" enctype="multipart/form-data">
				{% include "Blocks/formHeader.twig" %}

				<h2>
					Bloky
				</h2>
				<ul>
					{% for postBlock in post.getPostBlocks %}
						<li>
							{% include "Posts/Blocks/Kinds/#{postBlock.getKind.getCode}/edit.twig" %}
						</li>
					{% endfor %}
				</ul>

				<h2>
					Přidat blok
				</h2>
				<ul>
					{% for kind in kinds %}
						<li>
							<a href="{{ url("postBlocks.create", { postId: post.getId, kindCode: kind.getCode }) }}">
								{{ kind.getTitle }}
							</a>
						</li>
					{% endfor %}
				</ul>

				<button class="btn btn-primary" type="submit">
					S
				</button>

			</form>

			</div>
		</div>
	</div>

{% endblock body %}
